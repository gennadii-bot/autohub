# AvtoHub KZ — copy to .env and fill values

# Environment (development | production)
APP_ENV=development
ENVIRONMENT=development
# DEBUG must be false in production
DEBUG=false

# PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://avtohub:avtohub_secret@localhost:5432/avtohub

# Optional: sync URL for Alembic offline mode
# DATABASE_SYNC_URL=postgresql://avtohub:avtohub_secret@localhost:5432/avtohub

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# JWT — use openssl rand -hex 32 for production
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# Alternative: JWT_SECRET (same as SECRET_KEY)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated, restrict in production)
# Client: 5173, Admin: 5174, Partner: 5175
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175

# Telegram Bot (уведомления при booking)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Resend (partner activation emails)
RESEND_API_KEY=re_your_resend_api_key
# Optional: verified sender, e.g. "AvtoHub <noreply@avtohub.kz>"; fallback: SMTP_FROM
# RESEND_FROM=AvtoHub <noreply@avtohub.kz>
PARTNER_FRONTEND_URL=http://localhost:5175
ACTIVATION_TOKEN_EXPIRE_HOURS=24
